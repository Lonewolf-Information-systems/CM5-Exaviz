_cfg=/boot/firmware/config.txt
_fragment=/usr/share/exaviz/config-fragment.txt
_marker="# Exaviz Cruiser CM5 — appended by exaviz-dt-overlays"

post_install() {
    if [[ ! -f "${_cfg}" ]]; then
        echo "  [exaviz] No config.txt found — skipping (UEFI path assumed)"
        return
    fi

    # HARD GUARD: if UEFI firmware present, never touch config.txt
    if grep -q "armstub=RPI_EFI.fd" "${_cfg}"; then
        echo "  [exaviz] UEFI boot detected — config.txt protected, not modified"
        echo "  [exaviz] GRUB fragment installed: /etc/grub.d/10_exaviz_dtb"
        echo "  [exaviz] Run: grub-mkconfig -o /boot/grub/grub.cfg"
        return
    fi

    # RPi firmware path — append once, idempotent
    if grep -q "${_marker}" "${_cfg}"; then
        echo "  [exaviz] config.txt already contains Exaviz fragment — skipped"
    else
        echo "" >> "${_cfg}"
        cat "${_fragment}" >> "${_cfg}"
        echo "  [exaviz] Appended overlay config to config.txt"
        echo "  [exaviz] Reboot to activate dtoverlay=cruiser-raspberrypi-cm5"
    fi
}

post_upgrade() { post_install; }

pre_remove() {
    if [[ -f "${_cfg}" ]] && ! grep -q "armstub=RPI_EFI.fd" "${_cfg}"; then
        sed -i "/${_marker}/,\$d" "${_cfg}"
        echo "  [exaviz] Removed Exaviz fragment from config.txt"
    fi
}
