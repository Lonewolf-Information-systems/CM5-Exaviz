pkgname=metis-sdk
pkgver=1.5.0
pkgrel=1
pkgdesc="Axelera Metis native C++ SDK"
arch=('x86_64' 'aarch64')
url="https://github.com/axelera-ai-hub/voyager-sdk"
license=('Apache')
depends=('gcc-libs')
makedepends=('cmake' 'make')
source=("$pkgname-$pkgver::https://github.com/axelera-ai-hub/voyager-sdk/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
	cd voyager-sdk-$pkgver
	make
}

package() {
	cd voyager-sdk-$pkgver
	make DESTDIR="$pkgdir" install || true
}
